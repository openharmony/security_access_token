import("//build/test.gni")
import("../../privacy_manager.gni")
import("${access_token_path}/services/test/mock/account/account_mock.gni")

account_mock_base_external_deps =
    filter_exclude(privacy_manager_base_config.external_deps,
                   [ "os_account:os_account_innerkits_lite" ])

if (is_standard_system && ability_base_enable == true) {
  ohos_unittest("libprivacy_manager_service_coverage_test") {
    subsystem_name = "accesscontrol"
    module_out_path = module_output_path_unittest_privacy
    sanitize = {
      cfi = true
      cfi_cross_dso = true
      debug = false
    }
    branch_protector_ret = "pac_ret"

    include_dirs = account_mock_include_dirs
    include_dirs += privacy_manager_base_config.include_dirs
    include_dirs += [
      "${access_token_path}/interfaces/innerkits/nativetoken/include",
      "${access_token_path}/interfaces/innerkits/privacy/test/unittest/src",
    ]

    sources = privacy_manager_base_config.sources
    sources += account_mock_sources
    sources += [
      "${access_token_path}/interfaces/innerkits/privacy/test/unittest/src/privacy_test_common.cpp",
      "record/permission_record_manager_coverage_test.cpp",
      "sensitive/sensitive_manager_coverage_test.cpp",
    ]

    cflags_cc = privacy_manager_base_config.cflags_cc
    cflags_cc += account_mock_cflags_cc

    configs = privacy_manager_base_config.configs

    deps = privacy_manager_base_config.deps
    deps += [
      "${access_token_path}/interfaces/innerkits/nativetoken:libnativetoken_shared",
      "${access_token_path}/interfaces/innerkits/privacy:libprivacy_sdk",
      "${access_token_path}/interfaces/innerkits/token_setproc:libtokensetproc_shared",
      "${access_token_path}/services/common/proxy_death:proxy_death_stub",
    ]

    external_deps = account_mock_base_external_deps
    external_deps += [ "googletest:gtest_main" ]
  }
}

group("coverage_tests") {
  testonly = true
  deps = [ ":libprivacy_manager_service_coverage_test" ]
}
