ohos_unittest("libspm_data_task_test") {
  subsystem_name = "accesscontrol"
  module_out_path = module_output_path_unittest_accesstoken
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
    blocklist = "${access_token_path}/cfi_blocklist.txt"
  }
  branch_protector_ret = "pac_ret"

  include_dirs = accesstoken_manager_base_config.include_dirs
  include_dirs += [
    "${access_token_path}/interfaces/innerkits/accesstoken/test/unittest/common",
    "${access_token_path}/services/accesstokenmanager/test/unittest/service",
    "${access_token_path}/services/accesstokenmanager/test/unittest/permission",
    "${access_token_path}/services/accesstokenmanager/test/unittest/database",
    "${access_token_path}/services/accesstokenmanager/test/unittest/common",
    "${access_token_path}/interfaces/innerkits/nativetoken/include",
    "${access_token_path}/interfaces/innerkits/nativetoken/src",
  ]

  sources = [
    "common/fake_token_setproc.cpp",
    "common/parameter.cpp",
    "common/parameters.cpp",
    "permission/install_session_spm_task_test.cpp",
    "permission/spm_data_task_test.cpp",
    # Directly compile nativetoken sources instead of linking libnativetoken_shared
    # to avoid pulling in libpermsetproc_shared which contains real perm_setproc.cpp
    "${access_token_path}/interfaces/innerkits/nativetoken/src/nativetoken.c",
    "${access_token_path}/interfaces/innerkits/nativetoken/src/nativetoken_hisysevent.c",
    "${access_token_path}/interfaces/innerkits/nativetoken/src/nativetoken_json_oper.c",
  ]

  sources += accesstoken_manager_base_config.sources

  cflags_cc = accesstoken_manager_base_config.cflags_cc
  cflags_cc += [ "-DATM_TEST_ENABLE" ]

  configs = accesstoken_manager_base_config.configs

  # Don't depend on libaccesstoken_sdk as it pulls in libperm_setproc
  # which conflicts with fake_token_setproc.cpp
  # Also don't depend on libnativetoken_shared to avoid libpermsetproc_shared
  # Instead, compile nativetoken sources directly above
  deps = [
    "${access_token_path}/frameworks/common:accesstoken_common_cxx",
    "${access_token_path}/frameworks/common:accesstoken_permission_map_static",
  ]
  deps += accesstoken_manager_base_config.deps

  external_deps = [
    "googletest:gmock",
    "googletest:gtest_main",
  ]
  external_deps += accesstoken_manager_base_config.external_deps
}

