group("functional_tests") {
  testonly = true
  deps = [
    ":libaccesstoken_manager_service_standard_test",
  ]
  if (support_jsapi) {
    deps += [ ":libpermission_monitor_test" ]
  }
  if (access_token_enable_spm) {
    deps += [ ":libmigrate_installed_bundles_service_test" ]
  }
  if (access_token_manager_hapverify_enable) {
    deps += [
      ":libaccesstoken_manager_kernel_test",
      ":libboot_verify_scheduler_test",
      ":libspm_data_task_test",
      ":libhap_sign_verify_manager_test",
    ]
  }
}
